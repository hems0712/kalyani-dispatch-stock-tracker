
{
  "entities": {
    "PartStock": {
      "title": "Part Stock Record",
      "description": "Inventory and dispatch planning data for a specific manufacturing part.",
      "type": "object",
      "properties": {
        "partNumber": { "type": "string" },
        "pdiStock": { "type": "integer" },
        "plannedDispatch": { "type": "integer" },
        "v1Plan": { "type": "integer" },
        "v2Plan": { "type": "integer" },
        "v3Plan": { "type": "integer" },
        "v1Load": { "type": "integer" },
        "v2Load": { "type": "integer" },
        "v3Load": { "type": "integer" },
        "v1Shipped": { "type": "integer" },
        "v2Shipped": { "type": "integer" },
        "v3Shipped": { "type": "integer" },
        "shippedQuantity": { "type": "integer" },
        "planHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "string" },
              "quantity": { "type": "integer" }
            }
          }
        }
      },
      "required": ["partNumber", "pdiStock"]
    },
    "VehicleStatus": {
      "title": "Vehicle Status",
      "description": "Tracking state for a dispatch vehicle.",
      "type": "object",
      "properties": {
        "isDispatched": { "type": "boolean" },
        "dispatchedAt": { "type": "string", "format": "time" }
      }
    },
    "SystemSettings": {
      "title": "System Settings",
      "description": "Global system state including last reset date.",
      "type": "object",
      "properties": {
        "lastDate": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/parts/{partNumber}": {
      "schema": "PartStock",
      "description": "Collection of part inventory and dispatch data."
    },
    "/settings/vehicles": {
      "schema": "object",
      "description": "Global settings for vehicle dispatch statuses."
    },
    "/settings/system": {
      "schema": "SystemSettings",
      "description": "Internal system tracking for daily resets."
    }
  }
}
